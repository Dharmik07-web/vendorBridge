# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas (UPDATE WITH YOUR URI)
MONGO_URI=mongodb+srv://Hack123:8401103631@hack123.rewkk9c.mongodb.net/?appName=Hack123

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here_123
JWT_REFRESH_SECRET=your_refresh_token_secret_min_32_chars_here_456
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Nodemailer (SMTP) - Gmail Example
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=VendorBridge <noreply@vendorbridge.com>
